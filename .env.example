# AI Impact System — environment variables template
# Copy to .env for local dev. Set in Netlify dashboard for production.

# ═══════════════════════════════════════════════
# Existing site
# ═══════════════════════════════════════════════

# Calendly booking URL (existing homepage CTAs)
VITE_CALENDLY_URL=https://calendly.com/your-name/30min

# Contact email
VITE_CONTACT_EMAIL=marton.gaspar.uk@gmail.com

# Beehiiv embed URL (get from Beehiiv > Audience > Subscribe forms > Get embed code > copy iframe src)
# VITE_BEEHIIV_EMBED_URL=https://embeds.beehiiv.com/your-publication-id

# ═══════════════════════════════════════════════
# Scorecard — client-side (VITE_ prefix → bundled into frontend)
# ═══════════════════════════════════════════════

# Cal.com booking URL for the Diagnostic Call CTA on /audit/result
# Get this from: https://cal.com → your event → "Share" → copy URL
VITE_CAL_URL=https://cal.com/marton-gaspar/diagnostic-call

# Beta feature flag. Leave unset during the 15-person closed beta — only ?beta=true URLs see /audit.
# Set to "false" to open the scorecard to everyone.
# VITE_BETA_REQUIRED=true

# ═══════════════════════════════════════════════
# Scorecard — server-side (Netlify Functions only — never bundled to client)
# ═══════════════════════════════════════════════

# Supabase (new project for scorecard — separate from the Knowledge Base)
# Create at: https://supabase.com → New project
# Find the URL + service role key under Project Settings → API
SCORECARD_SUPABASE_URL=
SCORECARD_SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
# Sign up at: https://resend.com → Create API key
RESEND_API_KEY=
# Must be a verified sender on your domain once aiimpactsystem.com is verified in Resend
RESEND_FROM_EMAIL=Marton Gaspar <marton@aiimpactsystem.com>
